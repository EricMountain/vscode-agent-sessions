# node-pty ships Linux prebuilds under prebuilds/ but no darwin prebuild, so on
# macOS `npm install` compiles build/Release/pty.node from source instead (it's
# N-API/node-addon-api based, so this single binary loads fine across Node and
# Electron ABIs). Keep the compiled binary + its spawn helper and the bundled
# Linux prebuilds (so one .vsix serves both target platforms, per D5); drop
# everything else (gyp/Makefile intermediates, C++ sources, Windows-only
# deps/third_party).
node_modules/@homebridge/node-pty-prebuilt-multiarch/build/*.*
node_modules/@homebridge/node-pty-prebuilt-multiarch/build/Makefile
node_modules/@homebridge/node-pty-prebuilt-multiarch/build/gyp-mac-tool
node_modules/@homebridge/node-pty-prebuilt-multiarch/build/node-addon-api/**
node_modules/@homebridge/node-pty-prebuilt-multiarch/src/**
node_modules/@homebridge/node-pty-prebuilt-multiarch/deps/**
node_modules/@homebridge/node-pty-prebuilt-multiarch/third_party/**
node_modules/@homebridge/node-pty-prebuilt-multiarch/lib/*.test.js
node_modules/@homebridge/node-pty-prebuilt-multiarch/lib/*.test.js.map

# node-pty-prebuilt-multiarch depends on prebuild-install to fetch/compile its
# native binary at `npm install` time; that's already done by the time we
# package (see build/Release + prebuilds/ above), so none of it or its own
# transitive dependency tree is needed at runtime. node-addon-api is likewise
# only C++ headers used by node-gyp during that same build step. Excluding
# this whole tree drops the packaged file count from ~450 to ~120.
node_modules/prebuild-install/**
node_modules/@homebridge/node-addon-api/**
node_modules/node-addon-api/**
node_modules/base64-js/**
node_modules/bl/**
node_modules/buffer/**
node_modules/chownr/**
node_modules/decompress-response/**
node_modules/deep-extend/**
node_modules/detect-libc/**
node_modules/end-of-stream/**
node_modules/expand-template/**
node_modules/fs-constants/**
node_modules/github-from-package/**
node_modules/ieee754/**
node_modules/inherits/**
node_modules/ini/**
node_modules/mimic-response/**
node_modules/minimist/**
node_modules/mkdirp-classic/**
node_modules/napi-build-utils/**
node_modules/node-abi/**
node_modules/once/**
node_modules/pump/**
node_modules/rc/**
node_modules/readable-stream/**
node_modules/safe-buffer/**
node_modules/semver/**
node_modules/simple-concat/**
node_modules/simple-get/**
node_modules/string_decoder/**
node_modules/strip-json-comments/**
node_modules/tar-fs/**
node_modules/tar-stream/**
node_modules/tunnel-agent/**
node_modules/util-deprecate/**
node_modules/wrappy/**
